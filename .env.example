# Copy to .env. Loaded from project root when the app starts.
# PostgreSQL (staging) OR Microsoft SQL Server (production) only — no SQLite.
# ISTITHMAR_PG_* applies only to PostgreSQL. Production SQL Server uses ISTITHMAR_PRODUCTION_DATABASE_URL.

# staging | production | development
ISTITHMAR_ENV=staging

ISTITHMAR_SECRET_KEY=change-me-in-production

# --- SQL Server (ISTITHMAR_ENV=production) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_USER=admin_user
# Quote passwords that contain @ or ?
DB_PASSWORD="admin@12345?"
DB_NAME=estithmar_db
# Use Windows login instead of DB_USER / DB_PASSWORD (omit or ignore those when set):
# ISTITHMAR_MSSQL_USE_WINDOWS_AUTH=yes
# If error 18456 "Login failed": create a SQL login in SSMS, enable Mixed Mode, or use Windows auth above.

# Pytest uses database ISTITHMAR_PG_TEST_DATABASE (default estithmar_test); create it once (see scripts/postgres_create_test_db.sql)
# ISTITHMAR_PG_TEST_DATABASE=estithmar_test
# ISTITHMAR_TEST_DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@127.0.0.1:5432/estithmar_test

# Alternative: full URL (encode @ in password as %40)
# ISTITHMAR_STAGING_DATABASE_URL=postgresql+psycopg2://admin_user:PASS%40ENCODED@HOST:5432/estithmar_db

# --- Production — SQL Server (uncomment on production host) ---
# ISTITHMAR_ENV=production
# ISTITHMAR_PRODUCTION_DATABASE_URL=mssql+pyodbc://admin_user:PASS%40ENCODED@HOST:1433/estithmar_db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes

# Optional override for any environment
# ISTITHMAR_DATABASE_URL=...
# DATABASE_URL=...

# Schema: Flask-Migrate (Alembic). From project root: flask db upgrade
# After model changes: flask db migrate -m "message" && flask db upgrade
# Do not run "flask db init" — migrations/ is already in the repo (init is only for new projects).





# Database: PostgreSQL OR Microsoft SQL Server only (no SQLite).
#
# STAGING → PostgreSQL: keep ISTITHMAR_ENV=staging and set ISTITHMAR_PG_* below.
# PRODUCTION → SQL Server: on the prod server set ISTITHMAR_ENV=production, comment out
# staging block, and set ISTITHMAR_PRODUCTION_DATABASE_URL (mssql+pyodbc://...).
# The ISTITHMAR_PG_* variables are ONLY used for PostgreSQL, not for SQL Server.

ISTITHMAR_ENV=staging
ISTITHMAR_SECRET_KEY=dev-only-change-me-not-for-staging-or-production

# --- PostgreSQL (staging / local) — same logical names as prod if you like ---
ISTITHMAR_PG_HOST=127.0.0.1
ISTITHMAR_PG_PORT=5432
ISTITHMAR_PG_USER=admin_user
ISTITHMAR_PG_PASSWORD=Isth@12345
ISTITHMAR_PG_DATABASE=estithmar_db

# Optional: full PostgreSQL URL instead of ISTITHMAR_PG_* above
# ISTITHMAR_STAGING_DATABASE_URL=postgresql+psycopg2://admin_user:Isth%4012345@127.0.0.1:5432/estithmar_db

# --- Microsoft SQL Server (production host only) — uncomment and set host ---
# ISTITHMAR_ENV=production
# ISTITHMAR_PRODUCTION_DATABASE_URL=mssql+pyodbc://admin_user:Isth%4012345@YOUR_SQL_HOST:1433/estithmar_db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes
