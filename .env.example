# Copy to .env. Loaded from project root when the app starts.
# PostgreSQL (staging) OR Microsoft SQL Server (production) only — no SQLite.
# ESTITHMAR_PG_* applies only to PostgreSQL. Production SQL Server uses ESTITHMAR_PRODUCTION_DATABASE_URL.
# Legacy: variables named ISTITHMAR_* are still read and mapped to ESTITHMAR_* if the new name is unset.

# staging | production | development
ESTITHMAR_ENV=staging

ESTITHMAR_SECRET_KEY=change-me-in-production

# --- SQL Server (ESTITHMAR_ENV=production) ---
DB_HOST=127.0.0.1
DB_PORT=1433
DB_USER=admin_user
# Quote passwords that contain @ or ?
DB_PASSWORD="admin@12345?"
DB_NAME=estithmar_db
# Use Windows login instead of DB_USER / DB_PASSWORD (omit or ignore those when set):
# ESTITHMAR_MSSQL_USE_WINDOWS_AUTH=yes
# If error 18456 "Login failed": create a SQL login in SSMS, enable Mixed Mode, or use Windows auth above.

# Pytest uses database ESTITHMAR_PG_TEST_DATABASE (default estithmar_test); create it once (see scripts/postgres_create_test_db.sql)
# ESTITHMAR_PG_TEST_DATABASE=estithmar_test
# ESTITHMAR_TEST_DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@127.0.0.1:5432/estithmar_test

# Alternative: full URL (encode @ in password as %40)
# ESTITHMAR_STAGING_DATABASE_URL=postgresql+psycopg2://admin_user:PASS%40ENCODED@HOST:5432/estithmar_db

# --- Production — SQL Server (uncomment on production host) ---
# ESTITHMAR_ENV=production
# ESTITHMAR_PRODUCTION_DATABASE_URL=mssql+pyodbc://admin_user:PASS%40ENCODED@HOST:1433/estithmar_db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes

# Optional override for any environment
# ESTITHMAR_DATABASE_URL=...
# DATABASE_URL=...

# Schema: Flask-Migrate (Alembic). From project root: flask db upgrade
# After model changes: flask db migrate -m "message" && flask db upgrade
# Do not run "flask db init" — migrations/ is already in the repo (init is only for new projects).





# Database: PostgreSQL OR Microsoft SQL Server only (no SQLite).
#
# STAGING → PostgreSQL: keep ESTITHMAR_ENV=staging and set ESTITHMAR_PG_* below.
# PRODUCTION → SQL Server: on the prod server set ESTITHMAR_ENV=production, comment out
# staging block, and set ESTITHMAR_PRODUCTION_DATABASE_URL (mssql+pyodbc://...).
# The ESTITHMAR_PG_* variables are ONLY used for PostgreSQL, not for SQL Server.

ESTITHMAR_ENV=staging
ESTITHMAR_SECRET_KEY=dev-only-change-me-not-for-staging-or-production

# --- PostgreSQL (staging / local) — same logical names as prod if you like ---
ESTITHMAR_PG_HOST=127.0.0.1
ESTITHMAR_PG_PORT=5432
ESTITHMAR_PG_USER=admin_user
ESTITHMAR_PG_PASSWORD=Isth@12345
ESTITHMAR_PG_DATABASE=estithmar_db

# Optional: full PostgreSQL URL instead of ESTITHMAR_PG_* above
# ESTITHMAR_STAGING_DATABASE_URL=postgresql+psycopg2://admin_user:Isth%4012345@127.0.0.1:5432/estithmar_db

# --- Microsoft SQL Server (production host only) — uncomment and set host ---
# ESTITHMAR_ENV=production
# ESTITHMAR_PRODUCTION_DATABASE_URL=mssql+pyodbc://admin_user:Isth%4012345@YOUR_SQL_HOST:1433/estithmar_db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes

# --- Email (SMTP) — password reset & user invites ---
# ESTITHMAR_MAIL_SERVER=smtp.example.com
# ESTITHMAR_MAIL_PORT=587
# ESTITHMAR_MAIL_USE_TLS=true
# ESTITHMAR_MAIL_USERNAME=
# ESTITHMAR_MAIL_PASSWORD=
# ESTITHMAR_MAIL_SENDER=noreply@example.com

# --- WhatsApp (Twilio) — optional; also set ESTITHMAR_NOTIFY_WHATSAPP=1 ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# If phone numbers have no +country code, set default CC (digits only, no +):
# ESTITHMAR_WHATSAPP_DEFAULT_CC=966

# Public member self-registration (/register) — off by default
# ESTITHMAR_ALLOW_SELF_REGISTRATION=0
# Login OTP:
# - keep OTP enabled globally, but admin users are exempt by default
# - set this only if you want OTP forced for admin too
# ESTITHMAR_OTP_REQUIRE_ADMIN=1

# Optional: encrypt national ID at rest (Fernet). Generate once:  
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ESTITHMAR_ENCRYPTION_KEY=

# --- Certificate PDF (Playwright Chromium) ---
# pip install playwright && python -m playwright install chromium
# Set to 0 to return an error instead of legacy FPDF when HTML→PDF fails:
# ESTITHMAR_CERTIFICATE_PDF_FPDF_FALLBACK=1
# Optional: system Chrome/Chromium path if bundled browser is unavailable:
# ESTITHMAR_CHROMIUM_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe
# Sharper PDF (larger file): ESTITHMAR_CERTIFICATE_PDF_DEVICE_SCALE=2
